    "id": "split-readings",
    "type": "function",
    "z": "greenhouse-tab",
    "name": "Extract sensor 1",
    "func": "const data = msg.payload['1'] || {};\nif (!data) return null;\nmsg.air_temp_f = data.air_temp_f;\nmsg.humidity   = data.humidity;\nmsg.vpd        = data.vpd;\nmsg.moisture   = data.moisture;\nmsg.payload    = data;\nreturn msg;",
    "outputs": 1,
    "x": 500,
    "y": 80,
    "wires": [
      [
        "gauge-temp",
        "gauge-humidity",
        "gauge-vpd",
        "gauge-moisture",
        "gauge-ph",
        "gauge-soil-temp",
        "gauge-ec",
        "gauge-nitrogen",
        "gauge-phosphorus",
        "gauge-potassium"
      ]
    ]
