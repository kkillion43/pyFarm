  {
    "id": "history-parse",
    "type": "function",
    "z": "greenhouse-tab",
    "name": "Format for chart",
    "func": "const rows = msg.payload.slice().reverse();\nconst series = ['pH','Soil Temp \u00b0F','Moisture %','EC'];\nconst labels = rows.map(r => new Date(r.timestamp).getTime());\nconst data = [\n  rows.map(r => r.ph),\n  rows.map(r => r.soil_temp_f),\n  rows.map(r => r.moisture),\n  rows.map(r => r.electrical_conductivity)\n];\nmsg.payload = [{ series, data, labels }];\nreturn msg;",
    "outputs": 1,
    "x": 620,
    "y": 560,
    "wires": [
      [
        "chart-history"
      ]
    ]
  },
