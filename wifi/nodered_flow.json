    "z": "greenhouse-tab",
    "name": "Aggregate daily",
    "func": "const rows = msg.payload.slice().reverse();\nconst days = {};\nfor (const r of rows) {\n  const day = r.timestamp.substring(0, 10);\n  if (!days[day]) days[day] = {moisture:[], ph:[], ec:[], temp:[]};\n  if (r.moisture != null)                  days[day].moisture.push(r.moisture);\n  if (r.ph != null)                        days[day].ph.push(r.ph);\n  if (r.electrical_conductivity != null)   days[day].ec.push(r.electrical_conductivity);\n  if (r.soil_temp_f != null)               days[day].temp.push(r.soil_temp_f);\n}\nconst sorted = Object.keys(days).sort();\nconst avg = a => a.length ? +(a.reduce((x,y)=>x+y,0)/a.length).toFixed(2) : null;\nconst mn  = a => a.length ? +Math.min(...a).toFixed(2) : null;\nconst mx  = a => a.length ? +Math.max(...a).toFixed(2) : null;\nconst labels = sorted.map(d => new Date(d).getTime());\nconst moisture = { payload: [{ series: ['Avg','Min','Max'],\n  data: [sorted.map(d=>avg(days[d].moisture)), sorted.map(d=>mn(days[d].moisture)), sorted.map(d=>mx(days[d].moisture))], labels }] };\nconst ph = { payload: [{ series: ['Avg','Min','Max'],\n  data: [sorted.map(d=>avg(days[d].ph)), sorted.map(d=>mn(days[d].ph)), sorted.map(d=>mx(days[d].ph))], labels }] };\nconst ec = { payload: [{ series: ['Avg','Min','Max'],\n  data: [sorted.map(d=>avg(days[d].ec)), sorted.map(d=>mn(days[d].ec)), sorted.map(d=>mx(days[d].ec))], labels }] };\nconst temp = { payload: [{ series: ['Avg','Min','Max'],\n  data: [sorted.map(d=>avg(days[d].temp)), sorted.map(d=>mn(days[d].temp)), sorted.map(d=>mx(days[d].temp))], labels }] };\nreturn [moisture, ph, ec, temp];",
    "outputs": 4,
    "x": 610,
    "y": 1440,
    "wires": [
      [
        "chart-daily-moisture"
      ],
      [
        "chart-daily-ph"
      ],
      [
        "chart-daily-ec"
      ],
      [
        "chart-daily-temp"
      ]
    ]
  },
