  {
    "id": "soil-history-parse",
    "type": "function",
    "z": "greenhouse-tab",
    "name": "Format soil charts",
    "func": "const rows = msg.payload.slice().reverse();\nconst labels = rows.map(r => new Date(r.timestamp).getTime());\nconst npk      = { payload: [{ series: ['Nitrogen','Phosphorus','Potassium'], data: [rows.map(r => r.nitrogen), rows.map(r => r.phosphorus), rows.map(r => r.potassium)], labels }] };\nconst ec       = { payload: [{ series: ['EC (ppm)'], data: [rows.map(r => r.electrical_conductivity)], labels }] };\nconst moisture = { payload: [{ series: ['Soil Temp \u00b0F','Moisture %'], data: [rows.map(r => r.soil_temp_f), rows.map(r => r.moisture)], labels }] };\nconst ph       = { payload: [{ series: ['pH'], data: [rows.map(r => r.ph)], labels }] };\nreturn [npk, ec, moisture, ph];",
    "outputs": 4,
    "x": 610,
    "y": 1260,
    "wires": [
      [
        "chart-npk"
      ],
      [
        "chart-ec"
      ],
      [
        "chart-air-moisture"
      ],
      [
        "chart-ph"
      ]
    ]
  },
