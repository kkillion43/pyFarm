    "z": "greenhouse-tab",
    "name": "Fan out to switches",
    "func": "const s = msg.payload;\n// Send true/false to each switch so it reflects hardware state\nnode.send([\n  { payload: s.p_pump_1        === true, topic: 'p_pump_1' },\n  { payload: s.p_pump_2        === true, topic: 'p_pump_2' },\n  { payload: s.main_water_pump === true, topic: 'main_water_pump' },\n  { payload: s.trashcan        === true, topic: 'trashcan' }\n]);\nreturn null;",
