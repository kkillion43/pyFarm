    "name": "Route toggle",
    "func": "// msg.payload is true (on) or false (off)\n// msg.topic is the relay name\nconst base = 'http://100.89.173.109:8000/relays';\nif (msg.payload === true) {\n  msg.url = `${base}/${msg.topic}/on`;\n} else {\n  msg.url = `${base}/${msg.topic}/off`;\n}\nreturn msg;",
