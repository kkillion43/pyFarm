# =============================================================================
# Greenhouse Pi — Environment Variables Template
# Copy to .env and fill in your values.
# =============================================================================

# Tailscale pre-authorized auth key
# Get one at: https://login.tailscale.com/admin/settings/keys
# Mark: Reusable=true, Pre-authorized=true, Expiry=never
TAILSCALE_AUTH_KEY=tskey-auth-REPLACE_ME

# Tailscale IP of this Pi (used by Node-RED to reach the FastAPI server)
# Run: tailscale ip -4
TAILSCALE_IP=100.x.x.x

# Absolute path to the SQLite database file
DB_PATH=/home/pi/greenhouse/data/greenhouse.db

# Absolute path to the log file
LOG_FILE=/home/pi/greenhouse/logs/greenhouse.log

# RS-485 serial port device (ttyS0 = Pi hardware UART, ttyUSB0 = USB adapter)
SERIAL_PORT=/dev/ttyS0
